# Colab Backend Configuration
# Backend is running in Google Colab with ngrok tunnel
VITE_BACKEND_URL=https://armless-candle-duffel.ngrok-free.dev

# IMPORTANT: fetch / XHR calls go DIRECTLY to ngrok (header-capable, no proxy timeout).
# Only SSE (EventSource) goes through the Vite proxy — it cannot send custom headers.
# Update both values whenever ngrok gives you a new URL.
VITE_API_BASE=https://armless-candle-duffel.ngrok-free.dev
